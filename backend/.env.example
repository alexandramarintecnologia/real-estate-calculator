# ==============================================================================
# Servidor
# El backend corre en 4000 y el frontend (Next.js) en 3000 por defecto
# ==============================================================================
PORT=4000

# ==============================================================================
# CORS
# Dominio del frontend autorizado para hacer peticiones
# ==============================================================================
CORS_ORIGIN=http://localhost:3000

# ==============================================================================
# MongoDB
# Cadena de conexion a MongoDB (Atlas o local)
# Ejemplo local:  mongodb://localhost:27017/calculadora_inmobiliaria
# Ejemplo Atlas:  mongodb+srv://usuario:password@cluster.xxx.mongodb.net/calculadora_inmobiliaria
# ==============================================================================
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/calculadora_inmobiliaria

# ==============================================================================
# JWT
# Cambia JWT_SECRET por un valor largo y aleatorio en produccion
# ==============================================================================
JWT_SECRET=reemplaza-este-secreto-por-uno-muy-largo-y-aleatorio
JWT_EXPIRATION=7d

# ==============================================================================
# Usuario administrador inicial
# Se crea automaticamente la primera vez que arranca la app si no existe.
# Cambialo desde el panel /admin despues del primer login.
# ==============================================================================
ADMIN_EMAIL=admin@alexandramarin.com
ADMIN_PASSWORD=CambiaEstaPassword123!
